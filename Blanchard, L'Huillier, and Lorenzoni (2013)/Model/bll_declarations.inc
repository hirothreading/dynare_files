    m_p     ${m^p}$           (long_name='Price markup shock process')
    epsma_p ${\varepsilon^p}$ (long_name='Price markup innovation')
    m_w     ${m^w}$           (long_name='Wage markup shock process')
    epsma_w ${\varepsilon^w}$ (long_name='Wage markup innovation')
    g       ${g}$             (long_name='Government spending ratio shock')
    lam     ${\lambda}$       (long_name='Marginal utility of consumption')
    phi     ${\phi}$          (long_name='Multiplier on capital accumulation')
    c       ${c}$             (long_name='Consumption')
    i       ${inv}$           (long_name='Investment')
    kbar    ${\bar{k}}$       (long_name='Capital stock')
    kk      ${k}$             (long_name='Capital services')
    u       ${u}$             (long_name='Capital utilisation')
    y       ${y}$             (long_name='Output')
    n       ${n}$             (long_name='Labour')
    rk      ${r^k}$           (long_name='Capital rental rate')
    w       ${w}$             (long_name='Real wage')
    pi      ${\pi}$           (long_name='Inflation')
    mc      ${mc}$            (long_name='Marginal cost')
    mc_w    ${mc^w}$          (long_name='Wage markup gap')
    r       ${r}$             (long_name='Nominal interest rate')
    ri      ${i}$             (long_name='Ex ante real interest rate')
    ca      ${c^a}$           (long_name='Consumption with TFP trend')
    ia      ${i^a}$           (long_name='Investment with TFP trend')
    ya      ${y^a}$           (long_name='Output with TFP trend')
    ka      ${k^a}$           (long_name='Capital with TFP trend')
    wa      ${w^a}$           (long_name='Real wage with TFP trend')
    dca     ${\Delta c^a}$    (long_name='Consumption growth')
    diad    ${\Delta i^a}$    (long_name='Investment growth')
    dya     ${\Delta y^a}$    (long_name='Output growth')
    dn      ${\Delta n}$      (long_name='Labour growth')
    dwa     ${\Delta w^a}$    (long_name='Real wage growth')
    dr      ${\Delta r}$      (long_name='Nominal interest rate change')
    dpi     ${\Delta \pi}$    (long_name='Inflation change')
    dy      ${\Delta y}$      (long_name='Detrended output growth')
;

% e_1 and e_2 are orthogonal innovations of the equivalent full-information
% representation. They are transformed back to the three structural
% technology/noise shocks after solving the model.
varexo e_1    ${e_1}$           (long_name='EFI innovation 1')
       e_2    ${e_2}$           (long_name='EFI innovation 2')
       eps_d  ${\varepsilon^d}$ (long_name='Investment-specific technology shock')
       eps_p  ${\varepsilon^p}$ (long_name='Price markup shock')
       eps_w  ${\varepsilon^w}$ (long_name='Wage markup shock')
       eps_q  ${\varepsilon^q}$ (long_name='Monetary policy shock')
       eps_g  ${\varepsilon^g}$ (long_name='Government spending shock')
;

parameters rho    ${\rho}$       (long_name='Persistence of neutral technology growth')
           rho_d  ${\rho_d}$     (long_name='Persistence of investment-specific technology')
           rho_q  ${\rho_q}$     (long_name='Persistence of monetary policy shock')
           rho_p  ${\rho_p}$     (long_name='Persistence of price markup shock')
           rho_w  ${\rho_w}$     (long_name='Persistence of wage markup shock')
           rho_g  ${\rho_g}$     (long_name='Persistence of government spending shock')
           sig_u  ${\sigma_u}$   (long_name='Standard deviation of neutral technology shocks')
           sig_nu ${\sigma_\nu}$ (long_name='Standard deviation of noise shock')
           sig_d  ${\sigma_d}$   (long_name='Standard deviation of investment-specific shock')
           sig_q  ${\sigma_q}$   (long_name='Standard deviation of monetary policy shock')
           sig_p  ${\sigma_p}$   (long_name='Standard deviation of price markup shock')
           sig_w  ${\sigma_w}$   (long_name='Standard deviation of wage markup shock')
           sig_g  ${\sigma_g}$   (long_name='Standard deviation of government spending shock')
           zet    ${\zeta}$      (long_name='Inverse Frisch elasticity')
