           xi     ${\xi}$        (long_name='Capital utilisation cost')
           iot    ${\iota}$      (long_name='Price indexation')
           iot_w  ${\iota_w}$    (long_name='Wage indexation')
           psi    ${\psi}$       (long_name='Steady-state government spending to output ratio')
           cy_ratio              (long_name='Authors computational output-consumption ratio')
           cal    ${\theta}$     (long_name='Calvo parameter for prices')
           cal_w  ${\theta_w}$   (long_name='Calvo parameter for wages')
           mu_p   ${\mu_p}$      (long_name='Steady-state price markup')
           psi_p  ${\varphi_p}$  (long_name='Price markup MA coefficient')
           mu_w   ${\mu_w}$      (long_name='Steady-state wage markup')
           psi_w  ${\varphi_w}$  (long_name='Wage markup MA coefficient')
           rho_r  ${\rho_r}$     (long_name='Taylor rule persistence')
           gam_pi ${\gamma_\pi}$ (long_name='Taylor rule inflation coefficient')
           gam_y  ${\gamma_y}$   (long_name='Taylor rule output coefficient')
           BM_11 BM_12 BM_21 BM_22 BM_31 BM_32
           FA_11 FA_12 FA_13 FA_21 FA_22 FA_23
           CM_11 CM_12 CM_21 CM_22
